# Root .gitignore for the repository

# Go
bin/
obj/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
*.coverprofile

# Go build cache and temp files
/_output/
build/

# Vendor directory (if you keep vendor out of VCS)
vendor/

# Modules
Gopkg.lock

# Node / frontend
node_modules/
dist/
build/
/.vite
/frontend/node_modules/
/frontend/dist/

# Environment files - do NOT commit secrets
# .env
# .env.*
# .env.local
# .env.production
# frontend/.env
# frontend/.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Docker
*.tar
docker-compose.override.yml

# OS files
.DS_Store
Thumbs.db

# IDEs / editors
.vscode/
.idea/
*.iml
*.sublime-workspace

# Temporary files
*.swp
*~
.cache/
.tmp/

# Misc
coverage/
reports/
.cache-loader
